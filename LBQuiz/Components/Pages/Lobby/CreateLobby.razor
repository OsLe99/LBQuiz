@using Microsoft.AspNetCore.Components.Authorization
@using LBQuiz.Data
@using System.Security.Claims
@using Services.Interfaces 
@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext DbContext
@inject NavigationManager Navigation
@inject ILobbyService LobbyService


@page "/lobby/create"


<h3>CreateLobby</h3>

@if(isAuthenticated == true)
{
    @foreach (var quiz in _quizzes)
    {
        <MudItem>
            <MudLink Href="/">
                <MudPaper Class="pa-4" Style="height: 100px; border: 1px solid black; margin-bottom: 6px"
                @onclick="() => OnQuizClicked(quiz)">
                    <MudText Typo="Typo.h4">@quiz.Name</MudText>
                    <MudText Typo="Typo.h6">@quiz.Description</MudText>
                </MudPaper>
            </MudLink>
        </MudItem>
       
    }
    
}
else
{
    <MudText>You need to log in first!</MudText>
}


@code {

    private bool isAuthenticated;
    private List<Models.Quiz> _quizzes = new List<Models.Quiz>();




    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAuthenticated = user.Identity != null && user.Identity.IsAuthenticated;


        if(user != null)
        {
            var userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
            _quizzes = DbContext.Quiz.Where(q => q.HostId == userId).ToList();
        }

    }

    public async Task OnQuizClicked(Models.Quiz quiz)
    {
        //ska lägga till lobbyId för att veta vilken joinCode som ska visas på nästa sida
        // Uppdaterad för att kolla ifall användaren är inloggad, samt skicka med identity från authState
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (userId == null)
        {
            // Error hantering bör gå här
            return;
        }
        var lobby = await LobbyService.CreateLobbyAsync(quiz.Id, userId);
        Navigation.NavigateTo($"/quiz/{quiz.Id}/{lobby.Id}");
    }


}
