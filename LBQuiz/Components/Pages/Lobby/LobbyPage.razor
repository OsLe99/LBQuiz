@using LBQuiz.Models.Lobby
@using Microsoft.AspNetCore.SignalR.Client
@using LBQuiz.Services.Interfaces
@using LBQuiz.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject NavigationManager Navigation
@inject ILobbyHubConnection LobbyHub
@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IQRCodeService QRCodeService
@inject ILobbyService LobbyService
@inject IQuizManager QuizManager

@page "/quiz/{LobbyCode}"

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div class="createBar">
        <MudText Align="Align.Center" Typo="Typo.h5">
            Lobby: @LobbyCode
            <MudIcon Icon="@Icons.Material.Filled.Face" />
        </MudText>
    </div>

    @if (CurrentLobby == null)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (_isCountingDown)
    {
        <MudText Style="text-align: center;" Color="@countDownColor" Typo="Typo.h1">
            Quiz starting in @_countdownValue
        </MudText>
    }
    else
    {
        <div class="d-flex justify-center">
            <MudGrid Class="mt-2" Spacing="4" Style="max-width: 1000px; width: 100%;">
                <MudItem xs="12" md="4" Class="d-flex justify-center">
                    <MudCard Elevation="2" Style="width: 100%; max-width: 350px; height: 100%;">
                        <MudCardContent>
                            <MudText Typo="Typo.h6" Class="mb-4 text-center">Welcome to the lobby!</MudText>
                            @if (CurrentQuiz != null)
                            {
                                <div class="text-center">
                                    <MudText Typo="Typo.subtitle1" Class="mb-1">@CurrentQuiz.Name</MudText>
                                    <MudText Typo="Typo.body2">@CurrentQuiz.Description</MudText>
                                </div>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="4" Class="d-flex justify-center">
                    <MudCard Elevation="2" Style="width: 100%; max-width: 350px; height: 100%;">
                        <MudCardContent Class="d-flex flex-column align-center">
                            <MudText Typo="Typo.subtitle1" Class="mb-3 text-center">
                                Join Code: <strong>@CurrentLobby.JoinCode</strong>
                                <MudTooltip Text="Copy Code">
                                    <MudIconButton
                                        Icon="@Icons.Material.Filled.ContentCopy"
                                        Color="Color.Primary"
                                        Size="Size.Small"
                                        OnClick="CopyToClipboard">
                                    </MudIconButton>
                                </MudTooltip>
                            </MudText>
                            @if (_userId == CurrentQuiz?.HostId && qrImgString != null && qrImgString != "")
                            {
                                <div class="d-flex justify-center mt-2">
                                    <MudImage
                                        Src="@qrImgString"
                                        Style="max-height: 180px; max-width: 100%; border-radius: 8px;">
                                    </MudImage>
                                </div>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="4" Class="d-flex justify-center">
                    <MudCard Elevation="2" Style="width: 100%; max-width: 350px; height: 100%; display: flex; flex-direction: column;">
                        <MudCardContent Class="flex-grow-1 overflow-auto">
                            <MudText Typo="Typo.subtitle1" Class="mb-3 text-center">Players (@LobbyHub.Participants.Count)</MudText>
                            <MudList T="string">
                                @foreach (var part in LobbyHub.Participants)
                                {
                                    <MudListItem Class="justify-center">
                                        <MudChip
                                            Icon="@Icons.Material.Filled.AccountCircle"
                                            Color="Color.Primary"
                                            Variant="Variant.Outlined">
                                            @part.Nickname
                                        </MudChip>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </div>
        
        <div class="d-flex justify-center mt-4">
            @if (_userId == CurrentQuiz?.HostId)
            {
                <MudButton
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    OnClick="StartQuiz"
                    StartIcon="@Icons.Material.Filled.PlayArrow">
                    Start Quiz
                </MudButton>
            }
        </div>
    }
</MudContainer>

@code {
    // [Parameter]
    // public int QuizId { get; set; }
    // [Parameter]
    // public int LobbyId { get; set; }
    [Parameter]
    public string LobbyCode { get; set; }
    public QuizLobby CurrentLobby { get; set; }
    public Models.Quiz CurrentQuiz { get; set; }
    private string? _userId;
    private bool _quizStart = false;
    private string qrImgString;
    private bool _isCountingDown = false;
    private int _countdownValue = 5;
    private Color countDownColor = Color.Warning;

    protected override async Task OnInitializedAsync()
    {
        // Get current user ID
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirstValue(ClaimTypes.NameIdentifier);



        try
        {
            QuizLobby quizLobby = await LobbyService.GetLobbyByJoinCodeAsync(LobbyCode);
            CurrentLobby = quizLobby;
            CurrentQuiz = await QuizManager.GetQuizFromQuizId(CurrentLobby.QuizId);
            // CurrentQuiz = await DbContext.Quiz.Where(q => q.Id == CurrentLobby.QuizId).FirstOrDefaultAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Failed to retrieve data:" + ex);
        }

        await LobbyHub.InitializeAsync(Navigation, _userId);

        // Check if current user is the host
        bool isHost = CurrentQuiz != null && !string.IsNullOrEmpty(_userId) && _userId == CurrentQuiz.HostId;

        if (isHost)
        {
            // Host joins to receive events but is NOT added as a participant
            await LobbyHub.JoinLobbyAsHostAsync(CurrentLobby.Id);
        }

        await GenerateQrCode();

        LobbyHub.OnParticipantsChanged += async () =>
        {
            await InvokeAsync(StateHasChanged); // säker UI-tråd
        };
        LobbyHub.OnCountDownStart += OnStartCountDown;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            bool isHost = CurrentQuiz != null && !string.IsNullOrEmpty(_userId) && _userId == CurrentQuiz.HostId;
            if (!isHost)
            {
                var nickname = await JS.InvokeAsync<string>("sessionStorage.getItem", "lobbyNickname");
                if (!string.IsNullOrEmpty(nickname))
                {
                    await LobbyHub.RejoinLobbyAsync(CurrentLobby.Id, nickname);
                }
            }
        }
    }

    public async Task StartQuiz()
    {
        if (CurrentQuiz != null)
        {
            

            //Flytta till huben för att starta quiz-countdown på alla clients

            await LobbyHub.StartQuizAsync(CurrentLobby.Id, CurrentLobby.QuizId, _countdownValue);
        }
    }

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", CurrentLobby.JoinCode);
        Snackbar.Add("Copied to clipboard!", Severity.Success);
    }
    private async Task GenerateQrCode()
    {
        if (CurrentLobby != null)
        {
            // Generate QR code for the lobby join URL
            string lobbyUrl = Navigation.ToAbsoluteUri($"/quiz/{CurrentLobby.JoinCode}").ToString();
            qrImgString = await QRCodeService.GetQRImageFromApiAsync(LobbyCode);
            StateHasChanged();
        }
    }
    private async Task OnStartCountDown(int countDownTimer)
    {
        _isCountingDown = true;
        _countdownValue = countDownTimer;

        while (_countdownValue > 0)
        {
            await Task.Delay(1000);
            if (countDownColor == Color.Error) countDownColor = Color.Success;
            else countDownColor = Color.Error;
            _countdownValue--;
            await InvokeAsync(StateHasChanged);
        }

        _isCountingDown = false;
    }
}



