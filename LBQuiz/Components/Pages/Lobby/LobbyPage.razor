@using LBQuiz.Models.Lobby
@using Microsoft.AspNetCore.SignalR.Client
@using LBQuiz.Services.Interfaces
@using LBQuiz.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject NavigationManager Navigation
@inject ILobbyHubConnection LobbyHub
@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IQRCodeService QRCodeService
@inject ILobbyService LobbyService

@page "/quiz/{LobbyCode}"

<h3 style="text-align: center; margin-bottom: 40px;">LobbyPage</h3>

@if(_isCountingDown == false)
{
    @if (CurrentLobby == null)
    {
        <h1>Creating lobby...</h1>
    }
    else if (_quizStart == false)
    {
        <MudContainer Class="mb-5 d-flex-1">

            <MudPaper Style="background-color: lightgrey; height: 75vh;" Class="flex-grow-1">

                <MudGrid Justify="Justify.SpaceEvenly" Spacing="2">

                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.h4">Welcome to the lobby!</MudText>
                        @if (CurrentQuiz != null)
                        {
                            <div class="text-center mt-6">
                                <MudText Typo="Typo.h5">@CurrentQuiz.Name</MudText>
                                <MudText Typo="Typo.h6">@CurrentQuiz.Description</MudText>
                            </div>
                        }
                    </MudItem>

                    <MudItem>
                        <MudText Typo="Typo.h4">
                            Join Code: @CurrentLobby.JoinCode
                            <MudTooltip Text="Copy Code">
                                <MudFab StartIcon="@Icons.Material.Filled.ContentCopy" Color="Color.Primary" Size="Size.Small" OnClick="CopyToClipboard"></MudFab>
                            </MudTooltip>
                        </MudText>
                        @if (qrImgString != null && qrImgString != "")
                        {
                            <div class="d-flex justify-content-center mt-6">
                                <MudImage Src="@qrImgString" Style="max-height: 180px;" Class="rounded-lg"></MudImage>
                            </div>
                        }
                    </MudItem>

                    <MudItem>
                        <MudText Typo="Typo.h6">Number of players in lobby: @LobbyHub.Participants.Count</MudText>
                        <MudContainer Style="max-height: 70vh; overflow: scroll;">
                            <MudList T="string" ReadOnly="true">
                                @foreach (var part in LobbyHub.Participants)
                                {
                                    <MudListItem>
                                        <MudChip Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary">
                                            @part.Nickname
                                        </MudChip>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudContainer>

                    </MudItem>


                </MudGrid>

            </MudPaper>
            <div class="d-flex justify-content-center mt-4">
                @if (_userId == CurrentQuiz.HostId)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartQuiz">Start Quiz</MudButton>
                }
            </div>


        </MudContainer>

    }
}
else
{
    <MudText Style="text-align: center;" Color="@countDownColor" Typo="Typo.h1">Quiz starting in @_countdownValue</MudText>
}


@code {
    // [Parameter]
    // public int QuizId { get; set; }
    // [Parameter]
    // public int LobbyId { get; set; }
    [Parameter]
    public string LobbyCode { get; set; }
    public QuizLobby CurrentLobby { get; set; }
    public Models.Quiz CurrentQuiz { get; set; }
    private string? _userId;
    private bool _quizStart = false;
    private string qrImgString;
    private bool _isCountingDown = false;
    private int _countdownValue = 5;
    private Color countDownColor = Color.Warning;

    protected override async Task OnInitializedAsync()
    {
        // Get current user ID
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirstValue(ClaimTypes.NameIdentifier);

        CurrentLobby = await LobbyService.GetLobbyByJoinCodeAsync(LobbyCode);

        try
        {
            CurrentLobby = await DbContext.QuizLobby.Where(q => q.JoinCode == LobbyCode).FirstOrDefaultAsync();
            CurrentQuiz = await DbContext.Quiz.Where(q => q.Id == CurrentLobby.QuizId).FirstOrDefaultAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Failed to retrieve data:" + ex);
        }

        await LobbyHub.InitializeAsync(Navigation, _userId);

        // Check if current user is the host
        bool isHost = CurrentQuiz != null && !string.IsNullOrEmpty(_userId) && _userId == CurrentQuiz.HostId;

        if (isHost)
        {
            // Host joins to receive events but is NOT added as a participant
            await LobbyHub.JoinLobbyAsHostAsync(CurrentLobby.Id);
        }

        await GenerateQrCode();

        LobbyHub.OnParticipantsChanged += async () =>
        {
            await InvokeAsync(StateHasChanged); // säker UI-tråd
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            bool isHost = CurrentQuiz != null && !string.IsNullOrEmpty(_userId) && _userId == CurrentQuiz.HostId;
            if (!isHost)
            {
                var nickname = await JS.InvokeAsync<string>("sessionStorage.getItem", "lobbyNickname");
                if (!string.IsNullOrEmpty(nickname))
                {
                    await LobbyHub.RejoinLobbyAsync(CurrentLobby.Id, nickname);
                }
            }
        }
    }

    public async Task StartQuiz()
    {
        if (CurrentQuiz != null)
        {
            _isCountingDown = true;
            _countdownValue = 5;

            while(_countdownValue > 0)
            {
                await Task.Delay(1000);
                if (countDownColor == Color.Error) countDownColor = Color.Success;
                else countDownColor = Color.Error;
                _countdownValue--;
                StateHasChanged();
            }

            _isCountingDown = false;

            await LobbyHub.StartQuizAsync(CurrentLobby.Id, CurrentLobby.QuizId);
        }
    }

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", CurrentLobby.JoinCode);
        Snackbar.Add("Copied to clipboard!", Severity.Success);
    }
    private async Task GenerateQrCode()
    {
        if (CurrentLobby != null)
        {
            // Generate QR code for the lobby join URL
            string lobbyUrl = Navigation.ToAbsoluteUri($"/quiz/{CurrentLobby.JoinCode}").ToString();
            qrImgString = await QRCodeService.GetQRImageFromApiAsync(LobbyCode);
            StateHasChanged();
        }
    }
}



