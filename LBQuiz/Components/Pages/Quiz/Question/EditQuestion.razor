@using LBQuiz.Components.Helpers
@using Services.Interfaces
@using Models
@using System.Threading.Tasks
@using Pages.PopUps
@inject IQuestionManager QuestionManager
@inject IQuizManager QuizManager
@inject IQRCodeService QRCodeService
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService


@page "/quiz/question/update"


<AuthorizeView Context="authContext">
    <Authorized>
        
        <h3>Edit Question</h3>
        @if (SelectedQuestion == null)
        {
            @if (AllQuestions != null)
            {
                <MudDropContainer T="QuestionJsonBlob" Items="AllQuestions" ItemDropped="ItemUpdated" Class="d-flex flex-column" ItemsSelector="@((item, zone) => zone == "questions")" @key="AllQuestions">
                    <ChildContent>
                        <MudPaper>
                            <MudList T="QuestionJsonBlob">
                                <MudListSubheader>Question List</MudListSubheader>
                                <MudDropZone T="QuestionJsonBlob" AllowReorder="true" Identifier="questions"></MudDropZone>
                            </MudList>
                        </MudPaper>
                    </ChildContent>
                    <ItemRenderer>
                        <MudStack Row="true" AlignItems="AlignItems.Center" spacing="2" Style="max-width: 400px; overflow:clip">
                            <MudListItem T="QuestionJsonBlob" @onclick="() => OnQuestionClicked(context)">
                                @context.QuestionText
                            </MudListItem>
                            <MudButton OnClick="() => DeleteQuestionAsync(context)" Color="Color.Error">Delete</MudButton>
                        </MudStack>
                    </ItemRenderer>
                </MudDropContainer>
            }
            else
            {
                <MudGrid>
                    @if (AllQuizes != null)
                    {
                        @foreach (var item in AllQuizes)
                        {
                            <MudItem>
                                <MudPaper Class="editPaper pa-4" Style="border: 1px solid black; margin-bottom: 6px;"
                                          @onclick="() => OnQuizClicked(item)">
                                    <MudText Typo="Typo.h4">@item.Name</MudText>
                                    <MudText Typo="Typo.h6">@item.Description</MudText>
                                    <MudButton 
                                        OnClick="() => UpdateQuiz(item)"
                                        Class="mt-2"
                                        Variant="Variant.Filled"
                                        Color="Color.Primary">Update Quiz</MudButton>
                                    <MudButton
                                        OnClick="() => DeleteQuiz(item)"
                                        Class="mt-2"
                                        Variant="Variant.Filled"
                                        Color="Color.Error"
                                    >Delete Quiz</MudButton>
                                </MudPaper>
                            </MudItem>
                        }
                    }
                </MudGrid>
            }
        }
        else
        {
            @if (SelectedQuestion is QuestionOpen question)
            {
                <MudItem>
                    <MudPaper Class="editPaper pa-4" Style="height: 100px; border: 1px solid black; margin-bottom: 6px;">
                        <MudText>@question.QuestionText</MudText>
                    </MudPaper>
                    <MudPaper Class="pa-16 ma-2">
                        <MudTextField Label="New Question Text" @bind-Value="question.QuestionText" Variant="Variant.Filled"></MudTextField>
                        <MudTextField Label="New Question Answer" @bind-Value="question.CorrectAnswer" Variant="Variant.Filled"></MudTextField>
                        <MudTextField Label="New Question Points" @bind-Value="question.Points" Variant="Variant.Filled"></MudTextField>
                        <MudButton Variant="Variant.Filled" OnClick="() => SaveNewQuestionProps(question)" Style="margin-top: 10px; border: 1px solid rgba(0,0,0,0.4)">Save Changes</MudButton>
                    </MudPaper>
                </MudItem>
            }
            else if (SelectedQuestion is QuestionSlider questionSlider)
            {
                <MudItem>
                    <MudPaper>
                        <MudPaper Class="editPaper pa-4" Style="height: 100px; border: 1px solid black; margin-bottom: 6px;">
                            <MudText>@questionSlider.QuestionText</MudText>
                        </MudPaper>
                        <MudPaper Class="pa-16 ma-2">
                            <MudTextField Label="New Quesion Text" @bind-Value="@questionSlider.QuestionText" Variant="Variant.Filled"></MudTextField>
                            <MudTextField Label="New Minimum Value" @bind-Value="@questionSlider.MinValue" Variant="Variant.Filled"></MudTextField>
                            <MudTextField Label="New Maximum Value" @bind-Value="@questionSlider.MaxValue" Variant="Variant.Filled"></MudTextField>
                            <MudTextField Label="New Correct Value" @bind-Value="@questionSlider.CorrectValue" Variant="Variant.Filled"></MudTextField>
                            <MudButton Variant="Variant.Filled" @onclick="() => SaveNewQuestionProps(questionSlider)" Style="margin-top: 10px; border: 1px solid rgba(0,0,0,0.4)">Save Changes</MudButton>
                        </MudPaper>
                    </MudPaper>
                </MudItem>
            }
            else if (SelectedQuestion is MultipleChoice multipleQuestion)
            {
                <MudItem>
                    <MudPaper Class="editPaper pa-4" Style="height: 100px; border: 1px solid black; margin-bottom: 6px;">
                        <MudTextField Label="New Question Text" @bind-Value="@multipleQuestion.QuestionText" Variant="Variant.Filled"></MudTextField>
                    </MudPaper>
                </MudItem>
                <MudPaper Class="pa-16 ma-2">
                        <MudList T="String">
                            @foreach (var item in multipleQuestion.MultipleOptionsList)
                            {
                                <MudListItem Text="@item.Text"></MudListItem>
                                <MudStack Row="true" AlignItems="AlignItems.Center" spacing="2" Style="max-width: 400px; overflow:clip">
                                    <MudTextField Label="New Option Text" @bind-Value="@item.Text" Style="flex:1"></MudTextField>
                                    <MudCheckBox @bind-Value="item.CorrectFalse"></MudCheckBox>
                                </MudStack>

                            }
                        </MudList>
                        <MudButton @onclick="() => SaveNewQuestionProps(multipleQuestion)" Style="margin-top: 10px; border: 1px solid rgba(0,0,0,0.4)">Save</MudButton>
                </MudPaper>
            }
        }

    </Authorized>
    
    <NotAuthorized>
        <NotAuthorizedHelper/>
    </NotAuthorized>
    
</AuthorizeView>


@code {
    public List<Quiz> AllQuizes { get; set; }
    public List<QuestionJsonBlob> AllQuestions { get; set; }
    public Models.Question SelectedQuestion { get; set; }
    public string _currentUserId { get; set; }
    private Models.Question _question { get; set; }
    private bool _open;


    private void ToggleOpen() => _open = !_open;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            _currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            AllQuizes = await QuizManager.GetAllQuizesFromHostAsync(_currentUserId);
        }

        StateHasChanged();

    }
    public async Task OnQuizClicked(Quiz quiz)
    {
        AllQuestions = await QuestionManager.GetAllQuestionJsonBlobAsync(quiz.Id);
        AllQuestions = AllQuestions.OrderBy(q => q.SortOrder).ToList();
        StateHasChanged();
    }
    public async Task OnQuestionClicked(QuestionJsonBlob question)
    {
        SelectedQuestion = await QuestionManager.GetQuestionFromBlob(question);
    }
    public async Task SaveNewQuestionProps(Models.Question question)
    {
        await QuestionManager.UpdateQuestionText(question);
        _open = false;
    }
    private async Task ItemUpdated(MudItemDropInfo<QuestionJsonBlob> dropItem)
    {

        for(int i = 0; i < AllQuestions.Count; i++)
        {
            AllQuestions[i].SortOrder = i+1;
        }
        await QuestionManager.UpdateSortOrderAsync(AllQuestions);
    }
    private async Task DeleteQuestionAsync(QuestionJsonBlob question)
    {
        var parameters = new DialogParameters
        {
            {"ContentText" , $"Are you sure ypu want to delete {question.QuestionText}?"},
            {"ButtonText", "Delete"},
            {"Color", Color.Error}
        };

        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = DialogService.Show<ConfirmDialog>("Confirm Delete", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            AllQuestions = AllQuestions.Where(q => q != question).ToList();

            for(int i = 0; i < AllQuestions.Count; i++)
            {
                AllQuestions[i].SortOrder = i + 1;
            }

            await QuestionManager.DeleteQuestionAsync(question);

            await QuestionManager.UpdateSortOrderAsync(AllQuestions);

            StateHasChanged();
        }
    }
    private async Task DeleteQuiz(Quiz quiz)
    {
        var parameters = new DialogParameters
        {
            {"ContentText" , $"Are you sure ypu want to delete {quiz.Name}?"},
            {"ButtonText", "Delete"},
            {"Color", Color.Error}
        };

        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = DialogService.Show<ConfirmDialog>("Confirm Delete", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            AllQuizes = AllQuizes.Where(q => q != quiz).ToList();

            await QuizManager.DeleteQuizAsync(quiz);

            StateHasChanged();
        }
    }
    private async Task UpdateQuiz(Quiz quiz)
    {
        var parameters = new DialogParameters
        {
            {"updateQuiz", quiz},
            {"ButtonText", "Save"},
            {"Color", Color.Success}
        };

        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = DialogService.Show<UpdateQuiz>("Confirm Update", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await QuizManager.UpdateQuizAsync(quiz);
        }

    }
    private async Task TestQrCode()
    {
        await QRCodeService.GetQRImageFromApiAsync("jaja");
    }
}
