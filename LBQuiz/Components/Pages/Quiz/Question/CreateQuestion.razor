@page "/quiz/{QuizId:int}/question/create"
@inject IDbContextFactory<ApplicationDbContext> ContextFactory
@inject IQuestionManager QuestionManager
@inject NavigationManager NavigationManager
@using LBQuiz.Models;
@using Microsoft.EntityFrameworkCore
@using Data
@using LBQuiz.Components.Helpers
@using Services.Interfaces
@using Mono.TextTemplating
@using Models.Helpers

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            <div class="createBar">
                <MudText Align="Align.Center" Typo="Typo.h5">
                    Create a new question
                    <MudIcon Icon="@Icons.Material.Filled.QuestionAnswer"/>
                </MudText>
            </div>

    <MudGrid Class="mt-4">

        <MudItem xs="12" md="8">

            <MudCard Elevation="2" Class="pa-4">

                <MudText Typo="Typo.h6" Class="mb-2">
                    Question Settings
                </MudText>

                <MudSelect T="string"
                           @bind-Value="picked"
                           Label="Question Type"
                           Variant="Variant.Outlined"
                           AdornmentIcon="@Icons.Material.Filled.Quiz">

                    @foreach (var qt in questionTypes)
                    {
                        <MudSelectItem Value="@qt">@qt</MudSelectItem>
                    }

                </MudSelect>

                <MudDivider Class="my-4"/>

                @if (!string.IsNullOrEmpty(picked))
                {
                    <MudForm @ref="_questionForm">

                        <MudTextField @bind-Value="_questionText"
                                      Label="Question"
                                      Variant="Variant.Filled"
                                      Required="true"/>

                        @if (picked == "Open Question")
                        {
                            <MudTextField @bind-Value="_correctAnswer"
                                          Label="Correct Answer"
                                          Variant="Variant.Filled"/>
                        }

                        @if (picked == "Slider")
                        {
                            <MudNumericField @bind-Value="_minValue" Label="Min Value"/>
                            <MudNumericField @bind-Value="_maxValue" Label="Max Value"/>
                            <MudNumericField @bind-Value="_correctValue" Label="Correct Value"/>
                        }

                        @if (picked == "Multiple Picker")
                        {
                            <MudNumericField
                                @bind-Value="_numberOfOptions"
                                Label="Number of options"
                                @bind-Value:after="UpdateMultipleOptions"/>

                            @for (int i = 0; i < _numberOfOptions; i++)
                            {
                                var index = i;

                                <MudStack AlignItems="AlignItems.Center">

                                    <MudTextField @bind-Value="_multipleOptions[index].Text"
                                                  Label="Option"
                                                  Variant="Variant.Filled"/>

                                    <MudCheckBox
                                        @bind-Value="_multipleOptions[index].CorrectFalse"
                                        Color="Color.Success"/>

                                </MudStack>
                            }
                        }

                        @if (picked == "Word Cloud")
                        {
                            <MudNumericField
                                @bind-Value="_maxEntries"
                                Label="Max entries"/>
                        }

                        @if (picked == "Review")
                        {
                            <MudNumericField @bind-Value="_minValue" Label="Min"/>
                            <MudNumericField @bind-Value="_maxValue" Label="Max"/>
                        }

                        <MudNumericField @bind-Value="_questionPoints"
                                         Label="Points"
                                         Variant="Variant.Filled"/>

                        <MudButton Class="mt-4"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="SaveQuestion"
                                   StartIcon="@Icons.Material.Filled.Save">

                            Save Question

                        </MudButton>

                    </MudForm>
                }

            </MudCard>

        </MudItem>

        <MudItem xs="12" md="4">

            <MudCard Elevation="2" Class="pa-4">

                <MudText Typo="Typo.h6">
                    Questions in Quiz
                </MudText>

                <MudDivider Class="my-2"/>

                @if (_questions.Count == 0)
                {
                    <MudText Color="Color.Secondary">
                        No questions yet
                    </MudText>
                }
                else
                {
                    <MudStack Spacing="2" Style="width: 100%;">
                        @foreach (var q in _questions)
                        {
                            <MudPaper
                                Class="pa-3 d-flex flex-column"
                                Elevation="2"
                                Style="border-radius: 8px; background: white;">
                                
                                <MudStack
                                    Row="true"
                                    AlignItems="AlignItems.Center"
                                    Spacing="2"
                                    Class="mb-2">
                                    <MudIcon
                                        Icon="@GetIcon(q.Type)"
                                        Size="Size.Large"
                                        Color="Color.Primary"/>
                                    <MudText Typo="Typo.body2">
                                        @GetDisplayName(q.Type)
                                    </MudText>
                                </MudStack>
                                
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">
                                    @q.QuestionText
                                </MudText>
                            </MudPaper>
                        }
                    </MudStack>
                }

                <MudDivider Class="my-4"/>

                <MudText Typo="Typo.caption">
                    Total questions: @_numberOfQuestionsInQuiz
                </MudText>

            </MudCard>

        </MudItem>

    </MudGrid>

</MudContainer>

    </Authorized>
    
    <NotAuthorized>
        <NotAuthorizedHelper/>
    </NotAuthorized>

</AuthorizeView>



@code {
    [Parameter] public int QuizId { get; set; }

    private MudForm _questionForm;

    private string _questionText { get; set; } = string.Empty;
    private string _correctAnswer { get; set; } = string.Empty;
    private int _questionPoints { get; set; }
    public List<string> questionTypes = new() { "Open Question", "Slider", "Multiple Picker", "Word Cloud", "Review" };
    public string picked { get; set; }
    private int _minValue;
    private int _maxValue;
    private int _correctValue;
    private int _numberOfOptions = 0;
    private int _maxEntries;
    private List<MultipleOptions> _multipleOptions = new();
    private int _numberOfQuestionsInQuiz;
    private IDbContextFactory<ApplicationDbContext> _factory;
    private List<QuizQuestionPreview> _questions = new();

    public CreateQuestion(IDbContextFactory<ApplicationDbContext> dbContext)
    {
        _factory = dbContext;
    }

    protected override async Task OnInitializedAsync()
    {
        _questions = await QuestionManager.GetQuestionPreviewAsync(QuizId);
        _numberOfQuestionsInQuiz = await QuestionManager.GetNumberOfQuestionInQuizAsync(QuizId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveQuestion()
    {
        using var context = await _factory.CreateDbContextAsync();
        await _questionForm.Validate();
        if (picked == "Slider" && _minValue > _maxValue)
        {
            _questionText = "Your max value can not be lesser than your min value, try again";
            return;
        }

        if (!_questionForm.IsValid)
        {
            // Implementera error vid fel värden i form
            return;
        }

        if (picked == "Open Question")
        {
            await QuestionManager.CreateOpenQuestion(QuizId, _questionText, _correctAnswer, _questionPoints);
        }
        else if(picked == "Slider")
        {
            await QuestionManager.CreateSliderQuestion(QuizId, _minValue, _maxValue,_correctValue, _questionPoints, _questionText);
        }
        else if (picked == "Multiple Picker")
        {
            int id = 1;
            foreach(var m in _multipleOptions)
            {
                m.Id = id;
                m.ColorString = "rgba(255,0,0,0.4)";
                id++;
            }
            await QuestionManager.CreateMultipleChoiceQuestion(QuizId, _questionPoints, _questionText, _multipleOptions);
        }
        else if (picked == "Word Cloud")
        {
            await QuestionManager.CreateWordCloudQuestion(QuizId, _questionText, _maxEntries);
        }
        else if (picked == "Review")
        {
            await QuestionManager.CreateReviewQuestion(QuizId, _questionText, _minValue, _maxValue, _questionPoints);
        }

        try
        {
            await context.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"An error occurred while saving the question: {ex.Message}");
        }
        picked = "";
        _numberOfQuestionsInQuiz = await QuestionManager.GetNumberOfQuestionInQuizAsync(QuizId);
        _questions = await QuestionManager.GetQuestionPreviewAsync(QuizId);
        await InvokeAsync(StateHasChanged);
    }

    private void UpdateMultipleOptions()
    { 
        _multipleOptions = Enumerable
        .Range(0, _numberOfOptions)
        .Select(_ => new MultipleOptions()).ToList(); 
    }

    private string GetIcon(string type)
    {
        return type switch
        {
            "Open" => Icons.Material.Filled.Edit,
            "Slider" => Icons.Material.Filled.Tune,
            "Multiple" => Icons.Material.Filled.CheckBox,
            "WordCloud" => Icons.Material.Filled.Cloud,
            "Review" => Icons.Material.Filled.Star,
            _ => Icons.Material.Filled.Help
        };
    }
    private string GetDisplayName(string type)
    {
        return type switch
        {
            "Open" => "Open Question",
            "Slider" => "Slider",
            "Multiple" => "Multiple Choice",
            "WordCloud" => "Word Cloud",
            "Review" => "Review",
            _ => type
        };
    }
}