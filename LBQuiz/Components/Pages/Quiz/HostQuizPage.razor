@using LBQuiz.Services.Interfaces
@using LBQuiz.Hubs
@using LBQuiz.Models
@using LBQuiz.Models.Lobby
@using LBQuiz.Models.Helpers
@using Microsoft.EntityFrameworkCore
@using LBQuiz.Data
@using System.Text.Json
@inject ILobbyHubConnection LobbyHub
@inject ILobbyParticipantManager LobbyManager
@inject IQuestionManager questionManager


@page "/quiz/host/{quizId}/{lobbyId}"
@if (_showResults == true) // Show scoreboard
{
    <div style="background-color: aliceblue; min-height: 100vh; width: 100%;">
        <MudText Typo="Typo.h2" Align="Align.Center">Results</MudText>

        <MudContainer>
            <MudGrid Class="mb-4">
                
                @foreach (var part in _userList.Take(3).Select((p, index) => new {Player= p, Rank = index + 1}))
                {
                    <MudItem xs="4">
                        <MudPaper Class="ps-4 text-center" Style="background-color: lightblue">
                            <MudText Typo="Typo.h3">@part.Rank</MudText>
                            <MudText Typo="Typo.h4">@part.Player.Nickname</MudText>
                            <MudText Typo="Typo.body1" Color="Color.Primary">@part.Player.Score</MudText>
                        </MudPaper>
                    </MudItem>
                }

            </MudGrid>
        </MudContainer>
        
        <MudDivider DividerType="DividerType.Middle" Class="my-5"></MudDivider>
        
        <MudContainer Class="mb-5">
            <MudStack Spacing="2">
                @foreach (var part in _userList.Skip(3).Select((p, index) => new { Player = p, Rank = index + 4 }))
                {
                    <MudPaper Class="pe-2 d-flex justify-content-between align-items-center" Style="background-color: lightblue">
                        <MudText Typo="Typo.body1" Class="me-3">@part.Rank</MudText>
                        <MudText Typo="Typo.body1" Class="m3-3 flex-grow-1">@part.Player.Nickname</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Primary">@part.Player.Score</MudText>
                    </MudPaper>
                    <MudDivider DividerType="DividerType.Middle"></MudDivider>
                }
            </MudStack>
        </MudContainer>
        
        <MudContainer Class="d-flex justify-center mb-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EndQuiz">End Quiz</MudButton>
        </MudContainer>
    </div>

    
}
else // Questions
{

    <div class="hostPageContainer">
        <div>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Style="height: 250px; background-color: antiquewhite; border: 1px solid black">
                    <MudItem>@AllQuestions[_questionIndex].QuestionText</MudItem>
                </MudPaper>
                <MudButton Disabled="previousButton" OnClick="PreviousQuestion">Previous question</MudButton>
                <MudButton Disabled="nextButton" OnClick="NextQuestion">Next question</MudButton>
                <MudButton Disabled="_resultButton" OnClick="ShowResults">Show results</MudButton>
            </MudItem>
        </div>
        <div>
            <MudText Typo="Typo.h2" Align="Align.Center" Style="text-decoration: underline">Participants</MudText>
            <ul>
                @foreach (var user in _userList)
                {
                    <li>
                        <MudAvatar Color="Color.Tertiary"
                                   Size="Size.Small">
                            @user.Nickname[0]
                        </MudAvatar>
                        - @user.Nickname - @user.Score points
                    </li>
                }
                @foreach (var text in particapantSliderList)
                {
                    <li>
                        <p>@text</p>
                    </li>
                }
                @foreach (var text in _multipleAnswersList)
                {
                    <li>
                        <p>@text</p>
                    </li>
                }
            </ul>
        </div>
    </div>
}

@code {
    [Parameter] public string quizId { get; set; }
    [Parameter] public string lobbyId { get; set; }

    private ApplicationDbContext _dbContext;
    private bool previousButton = true;
    private bool nextButton = false;
    private bool _resultButton = true;
    private bool _showResults = false;
    private List<LobbyParticipant> _userList = new();
    private List<(LobbyParticipant Participant, string Answer)> _submittedAnswers = new();
    private int _questionIndex = 0;
    private List<QuestionJsonBlob> AllQuestions = new();
    private int? _score = 0;
    private List<string> particapantSliderList = new();
    private List<string> _multipleAnswersList = new();
    private List<LobbyParticipant> TopThree => _userList.Take(3).ToList();


    public HostQuizPage(ApplicationDbContext dbContext)
    {
        _dbContext = dbContext;
    }

    protected override void OnInitialized()
    {
        @foreach (var participant in LobbyHub.Participants)
        {
            _userList.Add(participant);
        }



        var selectedQuiz = _dbContext.Quiz.FirstOrDefault(q => q.Id == int.Parse(quizId));

        GetAllQuestionsFromQuiz().GetAwaiter().GetResult();

        LobbyHub.OnQuestionChanged += HandleNextQuestion;
        LobbyHub.OnAnswerRecieved += HandleAnswerRecieved;
        LobbyHub.OnCalculateScoreBoard += HandleScoreUpdate;
        LobbyHub.OnShowSliderValueToHost += HandleSliderValue;
        LobbyHub.OnShowMultipleAnswersToHost += HandleMultipleAnswers;
    }

    private async Task GetAllQuestionsFromQuiz()
    {
        var questions = _dbContext.QuestionJsonBlobs.Where(q => q.QuizId == int.Parse(quizId)).ToList();

        if (questions != null)
        {
            AllQuestions = questions;
        }
    }

    private async Task HandleNextQuestion(int questionIndex)
    {
        //Skapa logik f�r om man bara har en quetion i ett quiz.
        _questionIndex = questionIndex;
        if (_questionIndex == 0) previousButton = true;
        else if (_questionIndex == AllQuestions.Count - 1)
        {
            nextButton = true;
            _resultButton = false;
        }
        else if (AllQuestions.Count == 1)
        {
            previousButton = true;
            nextButton = true;
        }
        else
        {
            previousButton = false;
            nextButton = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task NextQuestion()
    {
        await LobbyHub.GoToNextQuestionAsync(_questionIndex, int.Parse(lobbyId));
        await InvokeAsync(StateHasChanged);
    }

    private async Task PreviousQuestion()
    {
        await LobbyHub.GoToPreviousQuestionAsync(_questionIndex, int.Parse(lobbyId));
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowResults()
    {
        _showResults = true;
        _userList = _userList.OrderByDescending(p => p.Score).ToList();
        await LobbyHub.GoToResultsAsync(_showResults, int.Parse(lobbyId), _userList);
        await InvokeAsync(StateHasChanged);
    }

    private async Task EndQuiz()
    {
        await LobbyHub.EndQuizAsync(int.Parse(lobbyId));
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleAnswerRecieved(string answer, LobbyParticipant participant)
    {
        _submittedAnswers.Add((participant, answer));
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleScoreUpdate(string answer, QuestionJsonBlob question, LobbyParticipant participant)
    {
        var existing = _userList.FirstOrDefault(p => p.ConnectionId == participant.ConnectionId);
        if (existing != null)
        {
            existing.Score = participant.Score;
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleSliderValue(int sliderValue, int quizId, LobbyParticipant lobbyParticipant, string questionText)
    {
        string sliderText = questionText + " : " + lobbyParticipant.Nickname + " set their slidervalue to: " + sliderValue;

        particapantSliderList.Add(sliderText);
        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleMultipleAnswers(LobbyParticipant participant, int quizId, List<MultipleOptions> participantAnswers, int questionId)
    {
        int numberOfCorrectAnswers = 0;
        
        var question = await questionManager.GetQuestionJsonBlobFromQuestionIdAsync(questionId);
        var optionsList = JsonSerializer.Deserialize<List<MultipleOptions>>(question.Blob);
        foreach(var result in optionsList)
        {
            foreach(var partAns in participantAnswers)
            {
                if(partAns.Text == result.Text)
                {
                    if (partAns.CorrectFalse == result.CorrectFalse) numberOfCorrectAnswers++;
                }
            }
        }
        _multipleAnswersList.Add($"{participant.Nickname} got {numberOfCorrectAnswers} correct answers out of {optionsList.Count}");
        await InvokeAsync(StateHasChanged);
    }
}