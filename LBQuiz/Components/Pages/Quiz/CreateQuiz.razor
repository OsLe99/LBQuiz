@page "/Quiz/Create"
@using Data
@using LBQuiz.Components.Helpers
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            <div class="createBar">
                <MudText Align="Align.Center" Typo="Typo.h5">
                    Create a New Quiz
                    <MudIcon Icon="@Icons.Material.Filled.BorderColor" />
                </MudText>
            </div>

            <MudPaper Class="pa-8 mt-4" Style="text-align: center; max-width: 500px; margin: 0 auto;">
                <MudStack Spacing="4">
                    <MudIcon Icon="@Icons.Material.Filled.Quiz" Style="font-size: 3rem;"/>
                    <MudText Typo="Typo.h6">Give your quiz a name and description to get started.</MudText>

                    <MudTextField @bind-Value="_quizName"
                                  Label="Quiz Name"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.DriveFileRenameOutline"
                                  Class="mt-4" />

                    <MudTextField @bind-Value="_quizDescription"
                                  Label="Quiz Description"
                                  Variant="Variant.Outlined"
                                  Lines="3"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Description" />

                    @if (!_quizSaved)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="SaveQuizToDatabase"
                                   Class="mt-4">
                            Save Quiz
                        </MudButton>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mt-4">
                            Your quiz was saved successfully!
                        </MudAlert>
                    }
                </MudStack>
            </MudPaper>
        </MudContainer>
    </Authorized>

    <NotAuthorized>
        <NotAuthorizedHelper />
    </NotAuthorized>
    
</AuthorizeView>

@code {
    private string _quizTypeValue { get; set; }
    private string _quizName { get; set; }
    private string _quizDescription { get; set; }
    private bool _quizSaved { get; set; } = false;
    private string _currentUserId; 

   

    private readonly IDbContextFactory<ApplicationDbContext> _factory;
    public CreateQuiz(IDbContextFactory<ApplicationDbContext> dbContext)
    {
        _factory = dbContext;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if(user.Identity?.IsAuthenticated == true)
        {
            _currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }
    }

    async Task SaveQuizToDatabase()  
    {
        using var context = await _factory.CreateDbContextAsync();
        var newQuiz = new Models.Quiz()
        {
            Name = _quizName,
            Description = _quizDescription,
            //HostId should always be the ID for the person who is logged in
            HostId = _currentUserId // TODO: Replace with actual logged-in user ID
        };
        context.Quiz.Add(newQuiz);
        try
        {
            await context.SaveChangesAsync();
            _quizSaved = true;
            NavigationManager.NavigateTo($"/quiz/{newQuiz.Id}/question/create");

        }
        catch (Exception ex)
        {
            Console.WriteLine($"An error occurred while saving the quiz: {ex.Message}");
        }
    }
}
