@page "/"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<MudContainer Class="mt-8" MaxWidth="MaxWidth.Large">
    
    <MudText Typo="Typo.h3" Class="mb-6">Welcome to LBQuiz</MudText>
    
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 250px">
                <MudText Typo="Typo.h6" Class="mb-3">Create Quizzes</MudText>
                <MudText>Build custom quizzes and share them with others.</MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 250px">
                <MudText Typo="Typo.h6" Class="mb-3">Take Quizzes</MudText>
                <MudText>Start quizzes as a host and let other join for a live quiz session.</MudText>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="height: 250px">
                <MudText Typo="Typo.h6" Class="mb-3">Anonymous Access</MudText>
                <MudText>No login required as a participant.</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

</MudContainer>

