@page "/chat"
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Nav
@rendermode InteractiveServer

<h3>SignalR test</h3>

<input @bind="message" placeholder="Skriv något…" />
<button @onclick="Send">Skicka</button>

<ul>
    @foreach (var msg in messages)
    {
        <li>@msg</li>
    }
</ul>

@code {
    private HubConnection? hub;
    private string message = "";
    private List<string> messages = new();

    protected override async Task OnInitializedAsync()
    {
        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/chathub"))
            .WithAutomaticReconnect()
            .Build();

        hub.On<string, string>("ReceiveMessage", (user, message) =>
        {
            messages.Add($"{user}: {message}");
            InvokeAsync(StateHasChanged);
        });

        await hub.StartAsync();
    }

    private async Task Send()
    {
        if (!string.IsNullOrWhiteSpace(message) && hub is not null)
        {
            await hub.SendAsync("SendMessage", "TestUser", message);
            message = "";
        }
    }
}
