@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Identity;
@using LBQuiz.Data;
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inherits LayoutComponentBase
@inject UserManager<ApplicationUser> userManager
@inject SignInManager<ApplicationUser> signInManager




<MudThemeProvider/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        
        <MudIconButton OnClick="@(() => OpenDrawer())" Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"></MudIconButton>
        
        <MudText Typo="Typo.h6" Class="ml-3">LBQuiz</MudText>
        <MudSpacer/>
        <AuthorizeView>
            <Authorized>
                <form method="post" action="/logout" style="display:inline">
                    <MudButton ButtonType="ButtonType.Submit"
                               Color="Color.Inherit"
                               Variant="Variant.Text">
                        Logout
                    </MudButton>
                </form>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/Account/Login" Variant="Variant.Text" Color="Color.Inherit">Login</MudButton>
                <MudButton Href="/Account/Register"
                           Variant="Variant.Text"
                           Color="Color.Inherit">
                    Register
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    
    <MudDrawer @bind-Open="_open" OverlayAutoClose="true" Elevation="1" ClipMode="DrawerClipMode.Docked">
        <MudDrawerHeader>
            <MudText Typo="Typo.h5">LBQuiz</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Outlined.Home">Home</MudNavLink>
            
            <MudNavGroup Title="Quiz Options">
                <MudNavLink Href="/quiz/create" Match="NavLinkMatch.All">Create Quiz</MudNavLink>
                <MudNavGroup Title="Edit A Quiz">
                    <MudNavLink Href=""></MudNavLink>
                </MudNavGroup>
            </MudNavGroup>
            
            <MudNavLink Href="/lobby/create">Host Quiz</MudNavLink>
            
            <MudNavLink Href="/about-us" Disabled="true">About Us</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>


@code{
    private bool _open = false;
    
    private void OpenDrawer()
    {
        _open = !_open;
    }
}
