@using LBQuiz.Services.Interfaces
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Identity;
@using LBQuiz.Data;
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject UserManager<ApplicationUser> userManager
@inject SignInManager<ApplicationUser> signInManager
@inject ILocalStorageService localStorage
@inherits LayoutComponentBase





<MudThemeProvider Theme="@LBQuiz.Themes.LBQuizCustomTheme.LBQuizTheme.Instance" @bind-IsDarkMode="_isDarkMode"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        
        <MudIconButton OnClick="@(() => ControlDrawer())" Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"></MudIconButton>
        
        <MudText Typo="Typo.h6" Class="ml-3">LBQuiz</MudText>
        <MudSpacer/>
        
        
        <AuthorizeView>
            <Authorized>
                <MudIconButton Href="/profile-picture">
                    @if (_profilePicExists == true)
                    {
                        <MudAvatar>
                            <MudImage Src="@_profilePicture"></MudImage>
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar>
                            <MudIcon Icon="@Icons.Material.Filled.AccountCircle"></MudIcon>
                        </MudAvatar>
                    }
                </MudIconButton>
                <form method="post" action="/logout" style="display:inline">
                    <MudButton ButtonType="ButtonType.Submit"
                               Color="Color.Inherit"
                               Variant="Variant.Text">
                        Logout
                    </MudButton>
                </form>
            </Authorized>

            <NotAuthorized>
                <MudButton Href="/Account/Login" Variant="Variant.Text" Color="Color.Inherit">Login</MudButton>
                <MudButton Href="/Account/Register"
                           Variant="Variant.Text"
                           Color="Color.Inherit">
                    Register
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
        <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick=DarkModeLocalStorage/>
    </MudAppBar>
    
    <MudDrawer @bind-Open="_open" OverlayAutoClose="true" Elevation="1" ClipMode="DrawerClipMode.Docked">
        <MudDrawerHeader>
            <MudText Typo="Typo.h5">LBQuiz</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Outlined.Home">Home</MudNavLink>
            
            <MudNavGroup Title="Quiz Options" Icon="@Icons.Material.Outlined.Settings">
                <MudNavLink Href="/quiz/create" Icon="@Icons.Material.Outlined.Quiz">Create Quiz</MudNavLink>
                <MudNavGroup Title="Edit A Quiz" Icon="@Icons.Material.Outlined.Edit">
                    <MudNavLink Href="/quiz/question/choose" Icon="@Icons.Material.Outlined.Add">Add Questions</MudNavLink>
                    <MudNavLink Href="quiz/question/update" Icon="@Icons.Material.Outlined.EditNote">Update or Remove Questions</MudNavLink>
                </MudNavGroup>
            </MudNavGroup>
            
            <MudNavLink Href="/lobby/create" Icon="@Icons.Material.Outlined.Assignment">Host Quiz</MudNavLink>
            
            <MudNavLink Href="/AboutUs" Icon="@Icons.Material.Outlined.Info" Disabled="false">About Us</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <div class="page-wrapper @(_isDarkMode ? "dark" : "")">
        <div class="aurora-main-bg"></div>
        <div class="page-content">
    <MudMainContent>
        @Body
    </MudMainContent>
        </div>
    </div>

    <CookieBanner />

    <footer class="mud-appbar mud-appbar-dense" style="position: relative; padding: 16px 24px;">
        <MudGrid Justify="Justify.Center" Spacing="2">
            <MudItem xs="12" sm="4" Class="text-center">
                <MudText Typo="Typo.subtitle2" Style="font-family: 'Fredoka One', cursive;">LBQuiz</MudText>
                <MudText Typo="Typo.caption">Create, host and take quizzes live.</MudText>
            </MudItem>
            <MudItem xs="12" sm="4" Class="text-center">
                <MudStack Spacing="0">
                    <MudLink Href="/" Typo="Typo.caption" Color="Color.Inherit">Home</MudLink>
                    <MudLink Href="/quiz/create" Typo="Typo.caption" Color="Color.Inherit">Create Quiz</MudLink>
                    <MudLink Href="/lobby/create" Typo="Typo.caption" Color="Color.Inherit">Host Quiz</MudLink>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="4" Class="text-center">
                <MudText Typo="Typo.caption">&copy; @DateTime.Now.Year LBQuiz. All rights reserved.</MudText>
            </MudItem>
        </MudGrid>
    </footer>

</MudLayout>


@code{
    private bool _open = false;
    private bool _isDarkMode = false;
    private string _profilePicture = "";
    private bool _profilePicExists = false;

    private void ControlDrawer()
    {
        _open = !_open;
    }

    protected override async Task OnInitializedAsync()
    {

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        //Hämta User från service, sätt _profilePicture till User.ProfilePicure;
        var currentUser = await userManager.GetUserAsync(user);
        if(currentUser != null)
        {
            var filePath = Path.Combine("wwwroot", currentUser.ProfilePicture.TrimStart('/').Replace('/', Path.DirectorySeparatorChar));
            if (currentUser != null)
            {
                _profilePicture = currentUser.ProfilePicture;
            }
            if (File.Exists(filePath))
            {
                _profilePicExists = true;
            }
            await InvokeAsync(StateHasChanged);
        }
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            string darkModeValue = await localStorage.GetLocalStorage("darkmode");
            if (darkModeValue == "True")
            {
                _isDarkMode = true;
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                _isDarkMode = false;
                await InvokeAsync(StateHasChanged);
            } 
        }
        
    }

    public async Task DarkModeLocalStorage()
    {
        _isDarkMode = !_isDarkMode;
        await localStorage.SetLocalStorage("darkmode", _isDarkMode.ToString());
    }
}
