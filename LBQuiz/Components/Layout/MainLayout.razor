@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" OnClick="@((e) => DrawerToggle())" Color="Color.Inherit"></MudIconButton>
        <MudText Typo="Typo.h6" Class="ml-3">LBQuiz</MudText>
        <MudSpacer/>
        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick=>Login</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary">Register</MudButton>
        <MudSwitch @bind-Value="_isDarkMode" Color="Color.Primary" Class="ml-4" T="bool" Label="Dark Mode"></MudSwitch>
    </MudAppBar>
    
    <MudDrawer @bind-Open="_drawerOpen">
        
    </MudDrawer>
    
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>


@code{
    private bool _drawerOpen = false;
    private bool _isDarkMode;
    private MudTheme _theme = new();

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;
}